# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# --- AWS Configuration ---
AWS_REGION=us-east-2

# --- App Configuration ---
APP_NAME=orders
STAGE=dev
COMPONENT=kinesis-archive

# --- Notifications ---
# Comma-separated list of emails to receive CloudWatch alarm notifications and pipeline approvals
ALERT_EMAILS=your@email.com

# --- Pipeline (required only to deploy the Pipeline stack) ---
# Your GitHub username or organization
GITHUB_OWNER=your-github-username

# ARN of the GitHub CodeStar Connection created in AWS Console
# AWS Console -> CodePipeline -> Settings -> Connections -> Create connection (GitHub)
# Must be set to "Available" status before deploying the Pipeline stack
CODESTAR_CONNECTION_ARN=arn:aws:codestar-connections:us-east-2:ACCOUNT_ID:connection/CONNECTION_ID

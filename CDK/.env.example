# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Personal/account-specific values (github owner, email, connection ARN) are stored
# in SSM Parameter Store, not here. Create them once with:
#
#   aws ssm put-parameter --region us-east-2 \
#     --name "/orders/pipeline/github_owner" --value "your-username" --type "String"
#
#   aws ssm put-parameter --region us-east-2 \
#     --name "/orders/pipeline/codestar_connection_arn" --value "arn:aws:codeconnections:..." --type "String"
#
#   aws ssm put-parameter --region us-east-2 \
#     --name "/orders/pipeline/alert_emails" --value "your@email.com" --type "String"

# --- App Configuration (optional — defaults shown) ---
AWS_REGION=us-east-2
APP_NAME=orders
STAGE=dev
COMPONENT=kinesis-archive

# --- Direct stack deploys only (optional) ---
# Used when running `cdk deploy Observability` directly (not via Pipeline)
# The Pipeline stack reads alert_emails from SSM instead
ALERT_EMAILS=your@email.com
